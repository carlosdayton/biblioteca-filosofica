# ========================================
# Backend Environment Variables
# ========================================

# PostgreSQL connection string
# Local development:
DATABASE_URL=postgresql+asyncpg://journal:journal@localhost:5432/philosophical_journal

# Production (Supabase):
# DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.xxx.supabase.co:5432/postgres

# Optional: protect the API with a simple key
# API_KEY=your-secret-key-here

# Comma-separated list of allowed CORS origins
# Local development:
CORS_ORIGINS=http://localhost:5173

# Production (Vercel):
# CORS_ORIGINS=https://your-app.vercel.app

# ========================================
# IMPORTANTE: NÃO COMMITE O ARQUIVO .env!
# Este é apenas um exemplo. Copie para .env
# e preencha com seus valores reais.
# ========================================
