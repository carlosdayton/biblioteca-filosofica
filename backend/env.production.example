# Exemplo de configuração para produção (PythonAnywhere + Supabase)
# Copie este arquivo para .env e substitua com suas credenciais reais

# Connection string do Supabase (use Transaction Pooler - porta 6543)
DATABASE_URL=postgresql+asyncpg://postgres.SEU_PROJETO_ID:SUA_SENHA@aws-1-sa-east-1.pooler.supabase.com:6543/postgres

# URL do frontend na Vercel
CORS_ORIGINS=https://seu-app.vercel.app

