# ========================================
# Frontend Environment Variables
# ========================================

# API URL
# Desenvolvimento local:
VITE_API_URL=http://localhost:8000

# Produção (escolha uma):
# Render:
# VITE_API_URL=https://diario-filosofico-api.onrender.com

# Railway:
# VITE_API_URL=https://seu-backend.railway.app

# Fly.io:
# VITE_API_URL=https://seu-backend.fly.dev

# ========================================
# IMPORTANTE: 
# - Para desenvolvimento local, use .env.local
# - Para produção, configure no Vercel Dashboard
# - NÃO commite arquivos .env com valores reais!
# ========================================
